# --- DeepL (free-text note translation) ---
# Get a free key at https://www.deepl.com/pro-api (free tier: 500,000 chars/month).
# Free-tier keys end in ":fx" — the server auto-detects this and routes to the
# free API endpoint instead of the paid one.
# Dev: read by the Vite proxy (vite-plugins/deepl-proxy.ts).
# Prod: set the SAME key in the Vercel project env (used by api/translate.ts).
DEEPL_API_KEY=

# --- Supabase (backend: auth, dashboards, CRM, survey, intakes) ---
# Create a project in the EU region (Frankfurt) for GDPR data residency.
# URL + anon key are safe to expose to the client; RLS is the real access boundary.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# --- Server-only secrets (set in Vercel/Supabase env, NEVER shipped to the client) ---
# Pepper for hashing guest phone numbers into pseudonyms (CRM plan). Long random string.
GUEST_HASH_SECRET=
