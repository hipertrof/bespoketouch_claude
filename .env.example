# --- DeepL (free-text note translation) ---
# Get a free key at https://www.deepl.com/pro-api (free tier: 500,000 chars/month).
# Free-tier keys end in ":fx" — the server auto-detects this and routes to the
# free API endpoint instead of the paid one.
# Dev: read by the Vite proxy (vite-plugins/deepl-proxy.ts).
# Prod: set the SAME key in the Vercel project env (used by api/translate.ts).
DEEPL_API_KEY=

# --- Supabase (backend: auth, dashboards, CRM, survey, intakes) ---
# Create a project in the EU region (Frankfurt) for GDPR data residency.
# URL + anon key are safe to expose to the client; RLS is the real access boundary.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# --- Server-only secrets (set in Vercel/Supabase env, NEVER shipped to the client) ---
# Pepper for hashing guest phone numbers into pseudonyms (opt-in CRM). Long random
# string. Read by api/guest.ts (prod) and vite-plugins/guest-proxy.ts (dev) to
# compute HMAC(phone, GUEST_HASH_SECRET + account_id). NEVER prefix with VITE_.
# ⚠️ Rotating this orphans every guest_profiles row — rotate only with a truncate.
GUEST_HASH_SECRET=

# Supabase service-role key — full god-mode DB access. Used by the service-role
# backends: staff invites (api/members.ts), guest CRM (api/guest.ts), and device
# pairing (api/device.ts kiosk-facing + api/pairing.ts manager-facing). NEVER
# prefix with VITE_ and NEVER import it into client code. Set it in the Vercel
# project env for prod; add it here only to test those endpoints against `vite dev`.
# Find it in Supabase Dashboard → Project Settings → API → service_role key.
SUPABASE_SERVICE_ROLE_KEY=
